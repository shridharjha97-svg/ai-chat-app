# Server
NODE_ENV=production
PORT=3000

# CORS
FRONTEND_URL=https://your-app.vercel.app
# Optional: comma-separated list if multiple frontends are used
FRONTEND_URLS=

# AI Providers
GROQ_API_KEY=
SARVAM_API_KEY=

# Auth protection (default true in production)
REQUIRE_AUTH=true

# Firebase Admin (for backend token verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
